# ─────────────────────────────────────────────
#  odkon-foundation — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=3000

# Database (Neon PostgreSQL — use the ?sslmode=require connection string)
# Format: postgresql://user:password@host/dbname?sslmode=require
# connection string - postgresql://neondb_owner:npg_3TvNhVfci5eM@ep-misty-poetry-at2752bk.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-jwt-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# CORS — the origin of your frontend (e.g. Vite dev server or production domain)
CORS_ORIGIN="http://localhost:5173"

# BCrypt rounds (12 is a good default; increase for higher security at cost of speed)
BCRYPT_ROUNDS=12
